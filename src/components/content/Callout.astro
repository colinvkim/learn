---
import { Info, Lightbulb, TriangleAlert } from "@lucide/astro";

interface Props {
  variant?: "note" | "tip" | "warning";
  title?: string;
}

const { variant = "note", title } = Astro.props;

const variants = {
  note: {
    label: "Note",
    icon: Info,
    shell: "border-accent/12 bg-accent-soft/60 dark:border-accent/14 dark:bg-accent-soft/26",
    badge: "bg-accent/8 text-accent dark:bg-accent/10 dark:text-accent",
  },
  tip: {
    label: "Tip",
    icon: Lightbulb,
    shell: "border-emerald-500/12 bg-emerald-500/5 dark:border-emerald-400/14 dark:bg-emerald-400/7",
    badge: "bg-emerald-500/9 text-emerald-700 dark:bg-emerald-400/12 dark:text-emerald-300",
  },
  warning: {
    label: "Warning",
    icon: TriangleAlert,
    shell: "border-amber-500/14 bg-amber-500/6 dark:border-amber-400/16 dark:bg-amber-400/8",
    badge: "bg-amber-500/9 text-amber-800 dark:bg-amber-400/12 dark:text-amber-300",
  },
} as const;

const config = variants[variant];
const Icon = config.icon;
---

<aside
  aria-label={title ?? config.label}
  class:list={[
    "my-6 rounded-[1rem] border px-4 py-4 shadow-soft sm:px-4.5",
    config.shell,
  ]}
>
  <div class="flex items-start gap-3.5">
    <div
      class:list={[
        "inline-flex h-7.5 w-7.5 shrink-0 items-center justify-center rounded-full ring-1 ring-black/5 dark:ring-white/8",
        config.badge,
      ]}
    >
      <Icon class="h-4 w-4" aria-hidden="true" />
    </div>

    <div class="min-w-0 flex-1 space-y-1.5">
      <div class="flex min-h-7.5 items-center">
        <p class="text-[0.9rem] font-semibold tracking-[-0.01em] text-ink">
          {title ?? config.label}
        </p>
      </div>

      <div
        class="text-[0.95rem] leading-7 text-muted [&_code]:rounded-md [&_code]:bg-black/5 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-[0.92em] [&_code]:text-ink dark:[&_code]:bg-white/7 [&_ol]:my-2.5 [&_ol]:list-decimal [&_ol]:space-y-1.5 [&_ol]:pl-5 [&_p]:my-2.5 [&_p:first-child]:mt-0 [&_p:last-child]:mb-0 [&_strong]:text-ink [&_ul]:my-2.5 [&_ul]:list-disc [&_ul]:space-y-1.5 [&_ul]:pl-5"
      >
        <slot />
      </div>
    </div>
  </div>
</aside>
