---
interface Props {
  id: string;
  question: string;
  options: string[];
  correctIndex: number;
  explanation?: string;
}

const { id, question, options, correctIndex, explanation } = Astro.props;
---

<div
  data-quiz
  data-quiz-id={id}
  data-correct-index={correctIndex}
  class="my-8 overflow-hidden rounded-[1.5rem] border border-line/80 bg-panel/92 shadow-soft"
>
  <div class="border-b border-line/80 bg-canvas/55 px-5 py-4 dark:bg-canvas/24">
    <div class="flex items-center justify-between gap-3">
      <p class="m-0 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-muted">
        Quick Check
      </p>
      <span class="rounded-full border border-line bg-panel/85 px-2.5 py-1 text-[0.68rem] font-medium text-muted">
        One answer
      </span>
    </div>
  </div>

  <div class="space-y-5 px-5 py-5">
    <div class="space-y-3">
      <p class="text-lg font-semibold tracking-[-0.02em] text-ink">
        {question}
      </p>
      <p class="text-sm leading-6 text-muted">
        Choose the best answer and use it to track your progress through the lesson.
      </p>
    </div>

    <div role="radiogroup" aria-label={question} class="grid gap-3">
      {options.map((option, index) => (
        <button
          type="button"
          role="radio"
          aria-checked="false"
          data-quiz-option={index}
          data-state="idle"
          class="group grid w-full grid-cols-[auto_1fr] items-start gap-3 rounded-[1.15rem] border border-line/80 bg-canvas/78 px-4 py-3.5 text-left transition hover:border-accent/35 hover:bg-canvas hover:text-ink focus-ring data-[state=correct]:border-emerald-500/35 data-[state=correct]:bg-emerald-500/10 data-[state=correct]:text-emerald-800 data-[state=incorrect]:border-amber-500/35 data-[state=incorrect]:bg-amber-500/10 data-[state=incorrect]:text-amber-800 data-[state=locked]:opacity-60 dark:data-[state=correct]:text-emerald-200 dark:data-[state=incorrect]:text-amber-200"
        >
          <span
            class="mt-0.5 inline-flex h-7 w-7 items-center justify-center rounded-full border border-line bg-panel text-xs font-semibold text-muted transition group-hover:border-accent/30 group-hover:text-ink group-data-[state=correct]:border-emerald-500/30 group-data-[state=correct]:bg-emerald-500/15 group-data-[state=correct]:text-emerald-700 group-data-[state=incorrect]:border-amber-500/30 group-data-[state=incorrect]:bg-amber-500/15 group-data-[state=incorrect]:text-amber-700 dark:group-data-[state=correct]:text-emerald-200 dark:group-data-[state=incorrect]:text-amber-200"
          >
            {String.fromCharCode(65 + index)}
          </span>
          <span class="pt-0.5 text-sm leading-6 text-ink/92">{option}</span>
        </button>
      ))}
    </div>

    <div class="flex flex-wrap items-center gap-3">
      <p
        data-quiz-feedback
        data-tone="neutral"
        hidden
        class="rounded-full border px-3 py-1.5 text-sm font-medium transition data-[tone=success]:border-emerald-500/30 data-[tone=success]:bg-emerald-500/10 data-[tone=success]:text-emerald-700 data-[tone=warning]:border-amber-500/30 data-[tone=warning]:bg-amber-500/10 data-[tone=warning]:text-amber-700 dark:data-[tone=success]:text-emerald-300 dark:data-[tone=warning]:text-amber-300"
        role="status"
      ></p>
    </div>

    {
      explanation && (
        <div
          data-quiz-explanation
          hidden
          class="rounded-[1.15rem] border border-line/80 bg-accent-soft/48 px-4 py-3.5"
        >
          <p class="text-sm font-semibold text-ink">Why that answer is correct</p>
          <p class="mt-1 text-sm leading-6 text-muted">{explanation}</p>
        </div>
      )
    }
  </div>
</div>
