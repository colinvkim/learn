---
type ColorState = {
  foreground?: string;
  background?: string;
  mixColor?: string;
  mixAmount?: number;
  tokenPrefix?: string;
};

interface Props {
  sampleText?: string;
  initial?: ColorState;
  showColorMix?: boolean;
}

const {
  sampleText = "Readable interface text",
  initial = {},
  showColorMix = true,
} = Astro.props;

const id = `color-${crypto.randomUUID()}`;
const state = {
  foreground: initial.foreground ?? "#1f2937",
  background: initial.background ?? "#f8fafc",
  mixColor: initial.mixColor ?? "#2563eb",
  mixAmount: initial.mixAmount ?? 20,
  tokenPrefix: initial.tokenPrefix ?? "card",
};
const data = { state };
---

<section
  id={id}
  data-color-lab
  data-state={JSON.stringify(data)}
  class="my-8 overflow-hidden rounded-panel border border-line/80 bg-panel/92 shadow-soft"
>
  <div class="grid gap-5 px-5 py-5 lg:grid-cols-[minmax(0,1fr)_minmax(18rem,0.82fr)]">
    <div class="min-w-0 space-y-4">
      <div class="grid gap-3 sm:grid-cols-2">
        <label class="grid gap-2 rounded-[0.85rem] border border-line/80 bg-canvas/45 p-3 text-sm text-muted">
          <span class="font-medium text-ink">foreground</span>
          <input data-color-control="foreground" type="color" value={state.foreground} class="h-10 w-full rounded-lg border border-line bg-panel p-1 focus-ring-subtle" />
        </label>
        <label class="grid gap-2 rounded-[0.85rem] border border-line/80 bg-canvas/45 p-3 text-sm text-muted">
          <span class="font-medium text-ink">background</span>
          <input data-color-control="background" type="color" value={state.background} class="h-10 w-full rounded-lg border border-line bg-panel p-1 focus-ring-subtle" />
        </label>
      </div>

      {showColorMix && (
        <div class="grid gap-3">
          <label class="grid gap-2 rounded-[0.85rem] border border-line/80 bg-canvas/45 p-3 text-sm text-muted">
            <span class="font-medium text-ink">mix color</span>
            <input data-color-control="mixColor" type="color" value={state.mixColor} class="h-10 w-full rounded-lg border border-line bg-panel p-1 focus-ring-subtle" />
          </label>
          <label class="grid gap-2 rounded-[0.85rem] border border-line/80 bg-canvas/45 p-3 text-sm text-muted">
            <span class="flex items-center justify-between gap-3"><span class="font-medium text-ink">mix amount</span><output data-color-output="mixAmount">{state.mixAmount}%</output></span>
            <input data-color-control="mixAmount" type="range" min="0" max="100" value={state.mixAmount} class="w-full accent-accent" />
          </label>
        </div>
      )}
    </div>

    <div class="min-w-0 space-y-4">
      <div class="rounded-[1rem] border border-line/80 bg-canvas/45 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-muted">Preview</p>
        <div data-color-preview class="mt-4 rounded-[0.85rem] border border-line/70 p-5 shadow-soft">
          <p class="text-xl font-semibold tracking-[-0.02em]">{sampleText}</p>
          <p class="mt-2 text-sm leading-6 opacity-80">Contrast must work before color choices can communicate.</p>
        </div>
        <div class="mt-3 grid gap-2 text-sm text-muted sm:grid-cols-3">
          <div><span class="font-medium text-ink">Ratio</span><br /><span data-color-ratio></span></div>
          <div><span class="font-medium text-ink">Normal text</span><br /><span data-color-normal></span></div>
          <div><span class="font-medium text-ink">Large text</span><br /><span data-color-large></span></div>
        </div>
      </div>

      <details class="rounded-[1rem] border border-line/80 bg-canvas/45 p-4">
        <summary class="cursor-pointer text-sm font-semibold text-ink focus-ring-subtle">
          Generated CSS
        </summary>
        <pre class="!mb-0"><code data-color-css class="language-css"></code></pre>
      </details>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const toRgb = (hex) => {
      const value = hex.replace("#", "");
      return [0, 2, 4].map((index) => Number.parseInt(value.slice(index, index + 2), 16));
    };
    const luminance = (hex) => {
      const [r, g, b] = toRgb(hex).map((value) => {
        const channel = value / 255;
        return channel <= 0.03928 ? channel / 12.92 : ((channel + 0.055) / 1.055) ** 2.4;
      });
      return 0.2126 * r + 0.7152 * g + 0.0722 * b;
    };
    const contrast = (foreground, background) => {
      const lighter = Math.max(luminance(foreground), luminance(background));
      const darker = Math.min(luminance(foreground), luminance(background));
      return (lighter + 0.05) / (darker + 0.05);
    };
    const mixHex = (base, mix, amount) => {
      const ratio = amount / 100;
      const mixed = toRgb(base).map((channel, index) => {
        return Math.round(channel * (1 - ratio) + toRgb(mix)[index] * ratio);
      });
      return `#${mixed.map((channel) => channel.toString(16).padStart(2, "0")).join("")}`;
    };

    const attach = () => {
      document.querySelectorAll("[data-color-lab]").forEach((root) => {
        if (!(root instanceof HTMLElement) || root.dataset.bound === "true") return;
        root.dataset.bound = "true";
        const config = JSON.parse(root.dataset.state || "{}");
        const state = { ...config.state };
        const preview = root.querySelector("[data-color-preview]");
        const ratio = root.querySelector("[data-color-ratio]");
        const normal = root.querySelector("[data-color-normal]");
        const large = root.querySelector("[data-color-large]");
        const css = root.querySelector("[data-color-css]");

        const read = () => {
          root.querySelectorAll("[data-color-control]").forEach((control) => {
            const key = control.dataset.colorControl;
            state[key] = control.type === "range" ? Number(control.value) : control.value;
          });
        };
        const writeControls = () => {
          Object.entries(state).forEach(([key, value]) => {
            const control = root.querySelector(`[data-color-control="${key}"]`);
            if (control) control.value = value;
          });
        };
        const render = () => {
          read();
          const mixedBackground = mixHex(state.background, state.mixColor, state.mixAmount);
          const ratioValue = contrast(state.foreground, mixedBackground);
          root.querySelectorAll("[data-color-output]").forEach((output) => {
            output.textContent = `${state[output.dataset.colorOutput]}%`;
          });
          if (preview instanceof HTMLElement) {
            preview.style.color = state.foreground;
            preview.style.background = mixedBackground;
          }
          if (ratio) ratio.textContent = `${ratioValue.toFixed(2)}:1`;
          if (normal) normal.textContent = ratioValue >= 4.5 ? "passes" : "fails";
          if (large) large.textContent = ratioValue >= 3 ? "passes" : "fails";
          if (css) css.textContent = `:root {\n  --${state.tokenPrefix}-text: ${state.foreground};\n  --${state.tokenPrefix}-surface: color-mix(in srgb, ${state.background}, ${state.mixColor} ${state.mixAmount}%);\n}\n\n.card {\n  color: var(--${state.tokenPrefix}-text);\n  background: var(--${state.tokenPrefix}-surface);\n}`;
        };

        root.querySelectorAll("[data-color-control]").forEach((control) => control.addEventListener("input", render));
        writeControls();
        render();
      });
    };
    document.addEventListener("astro:page-load", attach);
    attach();
  })();
</script>
