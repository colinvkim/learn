---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import "../../styles/global.css";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  title: string;
  description: string;
  showHeader?: boolean;
}

const { title, description, showHeader = true } = Astro.props;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : Astro.url;
---

<!doctype html>
<html lang="en" class="bg-canvas">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical.toString()} />
    <title>{title}</title>
    <Font cssVariable="--font-inter" preload />
    <ClientRouter />
    <script is:inline>
      (() => {
        const storageKey = "learn-theme";
        const root = document.documentElement;
        const getResolvedTheme = () => {
          const stored = localStorage.getItem(storageKey);
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;

          return stored === "light" || stored === "dark"
            ? stored
            : prefersDark
              ? "dark"
              : "light";
        };

        const theme = getResolvedTheme();
        root.classList.toggle("dark", theme === "dark");
        root.style.colorScheme = theme;
      })();
    </script>
  </head>
  <body class="min-h-screen bg-canvas text-ink">
    {
      showHeader && (
        <header class="h-16 border-b border-line/80 bg-canvas/90 backdrop-blur-sm">
          <div class="mx-auto flex h-full max-w-[90rem] items-center justify-between px-6 sm:px-8 lg:px-10">
            <a
              href="/"
              class="text-[0.95rem] font-semibold tracking-[-0.02em] text-ink hover:text-accent focus-visible:text-accent focus-visible:outline-none"
            >
              learn.colinkim.dev
            </a>
            <ThemeToggle />
          </div>
        </header>
      )
    }
    {
      !showHeader && (
        <div class="fixed right-5 top-5 z-20 sm:right-8">
          <ThemeToggle />
        </div>
      )
    }
    <slot />
    <script is:inline>
      (() => {
        const storageKey = "learn-theme";
        const root = document.documentElement;
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)");

        const getStoredTheme = () => {
          const stored = localStorage.getItem(storageKey);
          return stored === "light" || stored === "dark" ? stored : null;
        };

        if (!window.__learnThemeController) {
          const renderThemeIcon = (target, templateName) => {
            const template = document.querySelector(templateName);
            if (!(template instanceof HTMLTemplateElement)) return;
            target.replaceChildren(template.content.cloneNode(true));
          };

          const getResolvedTheme = () => {
            const stored = getStoredTheme();
            return stored ?? (prefersDark.matches ? "dark" : "light");
          };

          const sync = () => {
            const isDark = root.classList.contains("dark");
            root.style.colorScheme = isDark ? "dark" : "light";

            document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
              const label = button.querySelector("[data-theme-label]");
              const icon = button.querySelector("[data-theme-icon]");
              const nextTheme = isDark ? "light" : "dark";

              if (label) {
                label.textContent =
                  nextTheme === "dark" ? "Dark" : "Light";
              }

              if (icon instanceof HTMLElement) {
                renderThemeIcon(
                  icon,
                  nextTheme === "dark"
                    ? "[data-theme-icon-dark]"
                    : "[data-theme-icon-light]",
                );
              }
            });
          };

          const applyTheme = (theme, persist = true) => {
            root.classList.toggle("dark", theme === "dark");

            if (persist) {
              localStorage.setItem(storageKey, theme);
            }

            sync();
          };

          const restoreTheme = () => {
            applyTheme(getResolvedTheme(), false);
          };

          const toggleTheme = () => {
            const nextTheme = root.classList.contains("dark") ? "light" : "dark";
            const update = () => applyTheme(nextTheme);

            if (typeof document.startViewTransition === "function") {
              document.startViewTransition(update);
            } else {
              update();
            }
          };

          document.addEventListener("click", (event) => {
            if (!(event.target instanceof Element)) return;

            const button = event.target.closest("[data-theme-toggle]");
            if (!button) return;

            toggleTheme();
          });

          document.addEventListener("astro:after-swap", restoreTheme);
          document.addEventListener("astro:page-load", restoreTheme);

          prefersDark.addEventListener("change", (event) => {
            if (getStoredTheme()) return;
            applyTheme(event.matches ? "dark" : "light", false);
          });

          window.__learnThemeController = { sync, restoreTheme };
        }

        window.__learnThemeController.restoreTheme();
      })();
    </script>
  </body>
</html>
