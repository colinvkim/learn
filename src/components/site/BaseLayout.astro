---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import "../../styles/global.css";
import ProgressEnhancer from "./ProgressEnhancer.astro";
import ThemeToggle from "./ThemeToggle.astro";
import Analytics from "@vercel/analytics/astro";
import themeControllerScript from "../../lib/theme-controller.ts?raw";

interface Props {
  title: string;
  description: string;
  showHeader?: boolean;
}

const { title, description, showHeader = true } = Astro.props;
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : Astro.url;
---

<!doctype html>
<html lang="en" class="bg-canvas">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical.toString()} />
    <title>{title}</title>
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-jetbrains-mono" preload />
    <ClientRouter />
    <Analytics />
    <script is:inline set:html={themeControllerScript}></script>
  </head>
  <body class="min-h-screen bg-canvas text-ink">
    {
      showHeader && (
        <header class="sticky top-0 z-20 h-16 border-b border-line/80 bg-canvas/86 backdrop-blur-md">
          <div class="mx-auto flex h-full max-w-384 items-center justify-between px-4 sm:px-5 lg:px-6">
            <a
              href="/"
              class="text-[0.94rem] font-semibold tracking-[-0.02em] text-ink/90 hover:text-accent focus-visible:text-accent focus-visible:outline-none"
            >
              learn.colinkim.dev
            </a>
            <div class="flex min-w-0 items-center gap-2 sm:gap-3">
              <slot name="header-controls" />
              <ThemeToggle />
            </div>
          </div>
        </header>
      )
    }
    {
      !showHeader && (
        <div class="fixed right-4 top-4 z-20 sm:right-5 sm:top-5 lg:right-6 lg:top-6">
          <ThemeToggle />
        </div>
      )
    }
    <slot />
    <ProgressEnhancer />
  </body>
</html>
