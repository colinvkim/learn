---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-[0.82rem] font-medium tracking-[-0.01em] text-muted">
  <ol class="flex flex-wrap items-center gap-2">
    {
      items.map((item, index) => (
        <>
          <li>
            {item.href ? (
              <a class="hover:text-accent focus-visible:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/30 rounded" href={item.href}>
                {item.label}
              </a>
            ) : (
              <span class="text-ink">{item.label}</span>
            )}
          </li>
          {index < items.length - 1 && <li aria-hidden="true" class="text-muted/50">/</li>}
        </>
      ))
    }
  </ol>
</nav>
