---
interface Props {
  courseId: string;
  lessonSlug: string;
}

const { courseId, lessonSlug } = Astro.props;
---

<section
  data-lesson-progress
  data-course-id={courseId}
  data-lesson-slug={lessonSlug}
  class="overflow-hidden rounded-[1.6rem] border border-line/70 bg-[linear-gradient(180deg,color-mix(in_oklch,var(--color-panel),white_34%)_0%,var(--color-panel)_100%)] shadow-soft"
>
  <div class="border-b border-line/70 bg-[linear-gradient(135deg,color-mix(in_oklch,var(--color-canvas),white_20%)_0%,color-mix(in_oklch,var(--color-panel),white_6%)_100%)] px-5 py-5 dark:bg-[linear-gradient(135deg,color-mix(in_oklch,var(--color-canvas),black_8%)_0%,color-mix(in_oklch,var(--color-panel),white_4%)_100%)]">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div class="space-y-1">
        <div class="flex items-center gap-2.5">
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-muted">
            Lesson Progress
          </p>
          <span
            data-lesson-status-badge
            data-status-tone="neutral"
            class="hidden"
          >
            Not started
          </span>
        </div>
        <p class="text-base font-semibold tracking-[-0.01em] text-ink">
          Choose your progress for this lesson
        </p>
        <p
          data-lesson-status-summary
          class="hidden"
        >
          Mark the lesson manually or answer the quick checks to track progress.
        </p>
      </div>

      <div
        class="flex flex-wrap gap-2"
        role="group"
        aria-label="Set lesson progress status"
      >
        <button
          type="button"
          data-status-option="not-started"
          aria-pressed="true"
          class="rounded-full border border-line/80 bg-panel/88 px-4 py-2 text-sm font-medium text-muted transition hover:border-accent/30 hover:bg-panel hover:text-ink focus-ring data-[selected=true]:border-line/20 data-[selected=true]:bg-ink data-[selected=true]:text-white dark:data-[selected=true]:bg-white dark:data-[selected=true]:text-ink"
        >
          Not started
        </button>
        <button
          type="button"
          data-status-option="in-progress"
          aria-pressed="false"
          class="rounded-full border border-line/80 bg-panel/88 px-4 py-2 text-sm font-medium text-muted transition hover:border-accent/30 hover:bg-panel hover:text-ink focus-ring data-[selected=true]:border-amber-500/25 data-[selected=true]:bg-amber-500/14 data-[selected=true]:text-amber-700 dark:data-[selected=true]:text-amber-300"
        >
          In progress
        </button>
        <button
          type="button"
          data-status-option="completed"
          aria-pressed="false"
          class="rounded-full border border-line/80 bg-panel/88 px-4 py-2 text-sm font-medium text-muted transition hover:border-accent/30 hover:bg-panel hover:text-ink focus-ring data-[selected=true]:border-emerald-500/25 data-[selected=true]:bg-emerald-500/14 data-[selected=true]:text-emerald-700 dark:data-[selected=true]:text-emerald-300"
        >
          Completed
        </button>
      </div>
    </div>
  </div>

  <div class="px-5 py-5">
    <div
      data-lesson-quiz-summary
      class="rounded-[1.1rem] border border-line/70 bg-canvas/38 px-4 py-4"
    >
      <div class="flex items-center justify-between gap-4 text-sm">
        <p class="font-medium tracking-[0.01em] text-ink">Quick checks</p>
        <p data-lesson-quiz-progress class="text-muted">
          No quick checks in this lesson.
        </p>
      </div>

      <div class="mt-3 h-2.5 overflow-hidden rounded-full bg-line/70">
        <div
          data-lesson-quiz-bar
          class="h-full w-0 rounded-full bg-[linear-gradient(90deg,var(--color-accent),color-mix(in_oklch,var(--color-accent),white_22%))] transition-[width] duration-300"
        ></div>
      </div>
    </div>

    <button
      type="button"
      data-reset-lesson-progress
      hidden
      class="hidden"
    >
      Reset lesson
    </button>
  </div>
</section>
