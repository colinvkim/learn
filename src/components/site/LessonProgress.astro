---
interface Props {
  courseId: string;
  lessonSlug: string;
}

const { courseId, lessonSlug } = Astro.props;
---

<section
  data-lesson-progress
  data-course-id={courseId}
  data-lesson-slug={lessonSlug}
  class="group/lesson-progress overflow-hidden rounded-2xl border border-line/80 bg-panel/96 shadow-soft ring-1 ring-white/55 transition dark:ring-white/6 data-[status=in-progress]:border-amber-500/20 data-[status=in-progress]:shadow-[0_1px_2px_rgba(15,23,42,0.04),0_18px_40px_rgba(245,158,11,0.08)] data-[status=completed]:border-emerald-500/20 data-[status=completed]:shadow-[0_1px_2px_rgba(15,23,42,0.04),0_18px_40px_rgba(16,185,129,0.08)]"
>
  <div class="h-1 bg-line/60 transition group-data-[status=in-progress]/lesson-progress:bg-amber-500/80 group-data-[status=completed]/lesson-progress:bg-emerald-500/80"></div>

  <div class="px-5 py-4">
    <div class="grid gap-3 md:grid-cols-[minmax(0,1fr)_auto] md:items-center">
      <div class="min-w-0">
        <div class="flex items-center gap-2.5">
          <p class="text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-muted">
            Lesson Progress
          </p>
          <span
            data-lesson-status-badge
            data-status-tone="neutral"
            class="hidden"
          >
            Not started
          </span>
        </div>
        <p class="mt-1 text-base font-semibold tracking-[-0.02em] text-ink">
          Mark this lesson
        </p>
        <p data-lesson-status-summary class="hidden">
          Mark the lesson manually or answer the quick checks to track progress.
        </p>
      </div>

      <div
        class="inline-flex w-full flex-wrap gap-2 rounded-full border border-line/80 bg-canvas/40 p-1 md:w-auto md:flex-nowrap"
        role="group"
        aria-label="Set lesson progress status"
      >
        <button
          type="button"
          data-status-option="not-started"
          aria-pressed="true"
          class="rounded-full border border-transparent px-3.5 py-2 text-sm font-medium text-muted transition hover:text-ink focus-ring data-[selected=true]:border-line/80 data-[selected=true]:bg-canvas data-[selected=true]:text-ink dark:data-[selected=true]:bg-canvas/80"
        >
          Not started
        </button>
        <button
          type="button"
          data-status-option="in-progress"
          aria-pressed="false"
          class="rounded-full border border-transparent px-3.5 py-2 text-sm font-medium text-muted transition hover:text-ink focus-ring data-[selected=true]:border-amber-500/25 data-[selected=true]:bg-amber-500/14 data-[selected=true]:text-amber-700 dark:data-[selected=true]:text-amber-300"
        >
          In progress
        </button>
        <button
          type="button"
          data-status-option="completed"
          aria-pressed="false"
          class="rounded-full border border-transparent px-3.5 py-2 text-sm font-medium text-muted transition hover:text-ink focus-ring data-[selected=true]:border-emerald-500/25 data-[selected=true]:bg-emerald-500/14 data-[selected=true]:text-emerald-700 dark:data-[selected=true]:text-emerald-300"
        >
          Completed
        </button>
      </div>
    </div>
  </div>

  <button
    type="button"
    data-reset-lesson-progress
    hidden
    class="hidden"
  >
    Reset lesson
  </button>
</section>
