---
interface Props {
  courseId: string;
  lessonSlug: string;
}

const { courseId, lessonSlug } = Astro.props;
---

<section
  data-lesson-progress
  data-course-id={courseId}
  data-lesson-slug={lessonSlug}
  class="overflow-hidden rounded-[1.4rem] border border-line/80 bg-panel/92 shadow-soft"
>
  <div class="border-b border-line/80 bg-canvas/55 px-5 py-4 dark:bg-canvas/22">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
      <div class="space-y-2">
        <div class="flex items-center gap-2.5">
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-muted">
            Lesson Progress
          </p>
          <span
            data-lesson-status-badge
            data-status-tone="neutral"
            class="inline-flex rounded-full border px-2.5 py-1 text-[0.68rem] font-semibold tracking-[0.04em] text-muted transition data-[status-tone=neutral]:border-line data-[status-tone=neutral]:bg-panel/90 data-[status-tone=active]:border-amber-500/30 data-[status-tone=active]:bg-amber-500/10 data-[status-tone=active]:text-amber-700 data-[status-tone=complete]:border-emerald-500/30 data-[status-tone=complete]:bg-emerald-500/10 data-[status-tone=complete]:text-emerald-700 dark:data-[status-tone=active]:text-amber-300 dark:data-[status-tone=complete]:text-emerald-300"
          >
            Not started
          </span>
        </div>
        <p
          data-lesson-status-summary
          class="max-w-2xl text-sm leading-6 text-muted"
        >
          Mark the lesson manually or answer the quick checks to track progress.
        </p>
      </div>

      <div
        class="flex flex-wrap gap-2"
        role="group"
        aria-label="Set lesson progress status"
      >
        <button
          type="button"
          data-status-option="not-started"
          aria-pressed="true"
          class="rounded-full border border-line bg-panel/90 px-3.5 py-2 text-sm font-medium text-muted transition hover:border-accent/30 hover:text-ink focus-ring data-[selected=true]:border-line/20 data-[selected=true]:bg-ink data-[selected=true]:text-white dark:data-[selected=true]:bg-white dark:data-[selected=true]:text-ink"
        >
          Not started
        </button>
        <button
          type="button"
          data-status-option="in-progress"
          aria-pressed="false"
          class="rounded-full border border-line bg-panel/90 px-3.5 py-2 text-sm font-medium text-muted transition hover:border-accent/30 hover:text-ink focus-ring data-[selected=true]:border-amber-500/20 data-[selected=true]:bg-amber-500/12 data-[selected=true]:text-amber-700 dark:data-[selected=true]:text-amber-300"
        >
          In progress
        </button>
        <button
          type="button"
          data-status-option="completed"
          aria-pressed="false"
          class="rounded-full border border-line bg-panel/90 px-3.5 py-2 text-sm font-medium text-muted transition hover:border-accent/30 hover:text-ink focus-ring data-[selected=true]:border-emerald-500/20 data-[selected=true]:bg-emerald-500/12 data-[selected=true]:text-emerald-700 dark:data-[selected=true]:text-emerald-300"
        >
          Completed
        </button>
      </div>
    </div>
  </div>

  <div class="grid gap-4 px-5 py-4 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
    <div data-lesson-quiz-summary class="space-y-2">
      <div class="flex items-center justify-between gap-4 text-sm">
        <p class="font-medium text-ink">Quick checks</p>
        <p data-lesson-quiz-progress class="text-muted">
          No quick checks in this lesson.
        </p>
      </div>

      <div class="h-2 overflow-hidden rounded-full bg-line/75">
        <div
          data-lesson-quiz-bar
          class="h-full w-0 rounded-full bg-[linear-gradient(90deg,var(--color-accent),color-mix(in_oklch,var(--color-accent),white_22%))] transition-[width] duration-300"
        ></div>
      </div>
    </div>

    <button
      type="button"
      data-reset-lesson-progress
      hidden
      class="rounded-full border border-line bg-canvas/65 px-3.5 py-2 text-sm font-medium text-muted transition hover:border-accent/30 hover:text-ink focus-ring"
    >
      Reset lesson
    </button>
  </div>
</section>
