---
import { ListChecks } from "@lucide/astro";

interface Props {
  courseId: string;
  lessonSlug: string;
}

const { courseId, lessonSlug } = Astro.props;
---

<section
  data-lesson-progress
  data-course-id={courseId}
  data-lesson-slug={lessonSlug}
  aria-label="Lesson progress"
  class="group/lesson-progress rounded-[1.15rem] border border-line/80 bg-panel/92 px-4 py-3 shadow-soft ring-1 ring-white/55 transition duration-200 dark:ring-white/6 data-[status=in-progress]:border-accent/22 data-[status=completed]:border-emerald-500/25"
>
  <div class="flex flex-col items-center gap-3 lg:flex-row lg:justify-between">
    <div class="flex min-w-0 items-center self-start lg:self-auto">
      <p class="inline-flex items-center gap-2 text-sm font-medium tracking-[-0.02em] text-ink/88">
        <ListChecks class="h-4 w-4 text-muted" aria-hidden="true" />
        <span>Progress</span>
      </p>
    </div>

    <div class="w-full self-center lg:w-auto">
      <div
        class="grid min-w-0 grid-cols-3 gap-1 rounded-[0.95rem] border border-line/80 bg-canvas/72 p-1 lg:w-88"
        role="group"
        aria-label="Set lesson progress status"
      >
        <button
          type="button"
          data-status-option="not-started"
          aria-pressed="true"
          class="focus-ring rounded-[0.7rem] border border-transparent px-3 py-2 text-center text-[0.82rem] font-medium text-muted transition hover:text-ink data-[selected=true]:border-line/80 data-[selected=true]:bg-panel data-[selected=true]:text-ink"
        >
          Not started
        </button>
        <button
          type="button"
          data-status-option="in-progress"
          aria-pressed="false"
          class="focus-ring rounded-[0.7rem] border border-transparent px-3 py-2 text-center text-[0.82rem] font-medium text-muted transition hover:text-ink data-[selected=true]:border-accent/18 data-[selected=true]:bg-accent/10 data-[selected=true]:text-accent"
        >
          In progress
        </button>
        <button
          type="button"
          data-status-option="completed"
          aria-pressed="false"
          class="focus-ring rounded-[0.7rem] border border-transparent px-3 py-2 text-center text-[0.82rem] font-medium text-muted transition hover:text-ink data-[selected=true]:border-emerald-500/25 data-[selected=true]:bg-emerald-500/12 data-[selected=true]:text-emerald-700 dark:data-[selected=true]:text-emerald-300"
        >
          Completed
        </button>
      </div>
    </div>
  </div>

  <div
    data-lesson-quiz-summary
    class="mt-3 space-y-2 rounded-[0.95rem] border border-line/80 bg-canvas/52 px-3 py-3"
  >
    <div class="flex items-center justify-between gap-3">
      <p class="text-sm font-medium text-ink">Quick checks</p>
      <p data-lesson-quiz-progress class="text-sm text-muted">
        No quick checks in this lesson.
      </p>
    </div>
    <div class="h-1.5 overflow-hidden rounded-full bg-line/75">
      <div
        data-lesson-quiz-bar
        class="h-full w-0 rounded-full bg-[linear-gradient(90deg,var(--color-accent),color-mix(in_oklch,var(--color-accent),white_18%))] transition-[width] duration-300"
      >
      </div>
    </div>
    <p data-lesson-status-summary class="text-sm leading-6 text-muted">
      Mark lesson manually or answer quick checks to track progress.
    </p>
  </div>
</section>
