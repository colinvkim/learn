---
interface Props {
  courseId: string;
  lessonSlug: string;
}

const { courseId, lessonSlug } = Astro.props;
---

<section
  data-lesson-progress
  data-course-id={courseId}
  data-lesson-slug={lessonSlug}
  class="overflow-hidden rounded-2xl border border-line/80 bg-panel/96 shadow-soft ring-1 ring-white/55 dark:ring-white/6"
>
  <div
    class="border-b border-line/80 px-5 py-5"
  >
    <div
      class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between"
    >
      <div class="space-y-1">
        <div class="flex items-center gap-2.5">
          <p
            class="text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-muted"
          >
            Lesson Progress
          </p>
          <span
            data-lesson-status-badge
            data-status-tone="neutral"
            class="hidden"
          >
            Not started
          </span>
        </div>
        <p class="text-lg font-semibold tracking-[-0.03em] text-ink">
          Choose your progress for this lesson
        </p>
        <p data-lesson-status-summary class="hidden">
          Mark the lesson manually or answer the quick checks to track progress.
        </p>
      </div>

      <div
        class="flex flex-wrap gap-2"
        role="group"
        aria-label="Set lesson progress status"
      >
        <button
          type="button"
          data-status-option="not-started"
          aria-pressed="true"
          class="rounded-full border border-line/80 bg-canvas/70 px-3.5 py-2 text-sm font-medium text-muted transition hover:border-accent/30 hover:text-ink focus-ring data-[selected=true]:border-line/20 data-[selected=true]:bg-ink data-[selected=true]:text-white dark:data-[selected=true]:bg-white dark:data-[selected=true]:text-ink"
        >
          Not started
        </button>
        <button
          type="button"
          data-status-option="in-progress"
          aria-pressed="false"
          class="rounded-full border border-line/80 bg-canvas/70 px-3.5 py-2 text-sm font-medium text-muted transition hover:border-accent/30 hover:text-ink focus-ring data-[selected=true]:border-amber-500/25 data-[selected=true]:bg-amber-500/14 data-[selected=true]:text-amber-700 dark:data-[selected=true]:text-amber-300"
        >
          In progress
        </button>
        <button
          type="button"
          data-status-option="completed"
          aria-pressed="false"
          class="rounded-full border border-line/80 bg-canvas/70 px-3.5 py-2 text-sm font-medium text-muted transition hover:border-accent/30 hover:text-ink focus-ring data-[selected=true]:border-emerald-500/25 data-[selected=true]:bg-emerald-500/14 data-[selected=true]:text-emerald-700 dark:data-[selected=true]:text-emerald-300"
        >
          Completed
        </button>
      </div>
    </div>
  </div>

  <button
    type="button"
    data-reset-lesson-progress
    hidden
    class="hidden"
  >
    Reset lesson
  </button>
</section>
