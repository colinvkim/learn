---
import type { CourseEntry, LessonEntry } from "../../lib/content/queries";
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "./Breadcrumbs.astro";
import CourseSidebar from "./CourseSidebar.astro";

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description: string;
  course: CourseEntry;
  lessons: LessonEntry[];
  breadcrumbs: Crumb[];
  currentLessonSlug?: string;
}

const {
  title,
  description,
  course,
  lessons,
  breadcrumbs,
  currentLessonSlug,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto max-w-[96rem] px-4 pb-16 pt-8 sm:px-5 lg:h-[calc(100dvh-4rem)] lg:max-w-none lg:overflow-hidden lg:px-0 lg:pb-0 lg:pt-0">
    <div class="grid gap-8 lg:h-full lg:grid-cols-[17rem_minmax(0,1fr)] lg:gap-0">
      <div class="lg:h-full lg:overflow-hidden">
        <CourseSidebar
          course={course}
          lessons={lessons}
          currentLessonSlug={currentLessonSlug}
        />
      </div>

      <main class="min-w-0 lg:h-full lg:overflow-y-auto lg:overscroll-y-contain lg:border-l lg:border-line/80 lg:pl-8 xl:pl-10">
        <div class="mx-auto max-w-3xl space-y-7 pt-2 lg:min-h-full lg:py-10 xl:max-w-[46rem]">
          <Breadcrumbs items={breadcrumbs} />
          <slot />
        </div>
      </main>
    </div>
  </div>
</BaseLayout>
