---
import type { CourseSummary } from "../../lib/content/queries";
import { getCourseHref, getLessonHref, getLessonSlug } from "../../lib/content/queries";
import TopicMarks from "./TopicMarks.astro";

interface Props {
  summary: CourseSummary;
}

const { summary } = Astro.props;
const { course, lessonCount } = summary;
const topics = Array.isArray(course.data.topics) ? course.data.topics : [];
const firstLessonHref =
  summary.firstLesson ? getLessonHref(course.id, getLessonSlug(summary.firstLesson)) : getCourseHref(course.id);
---

<a
  href={firstLessonHref}
  aria-label={course.data.title}
  class="group relative flex h-full flex-col items-start gap-4 overflow-hidden rounded-xl border border-line/80 bg-panel/95 p-4 shadow-soft ring-1 ring-white/55 transition hover:-translate-y-0.5 hover:border-accent/30 hover:shadow-[0_1px_2px_rgba(15,23,42,0.04),0_24px_56px_rgba(15,23,42,0.08)] dark:ring-white/6 focus-ring"
>
  <TopicMarks topics={topics} />
  <div class="space-y-2">
    <h2 class="text-lg font-semibold tracking-[-0.04em] text-ink group-hover:text-accent">
      {course.data.title}
    </h2>
    <p class="inline-flex items-center rounded-full border border-line/80 bg-canvas/85 px-2 py-0.5 text-xs font-medium tracking-[-0.01em] text-muted dark:bg-canvas/60">
      {lessonCount} lesson{lessonCount === 1 ? "" : "s"}
    </p>
  </div>
</a>
