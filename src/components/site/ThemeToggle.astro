---
import { MoonStar, SunMedium } from "@lucide/astro";
---

<button
  type="button"
  data-theme-toggle
  class="inline-flex h-10 items-center gap-2 rounded-full border border-line/80 bg-panel/92 px-3 text-sm font-medium text-muted shadow-soft ring-1 ring-white/55 transition hover:border-accent/20 hover:text-ink dark:ring-white/8 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/30"
  aria-label="Toggle dark mode"
>
  <span class="inline-flex items-center justify-center" data-theme-icon>
    <MoonStar class="h-4 w-4" aria-hidden="true" />
  </span>
  <span data-theme-label>Theme</span>
</button>

<template data-theme-icon-dark>
  <MoonStar class="h-4 w-4" aria-hidden="true" />
</template>

<template data-theme-icon-light>
  <SunMedium class="h-4 w-4" aria-hidden="true" />
</template>
