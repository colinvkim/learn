---
import NpmIcon from "../icons/NpmIcon.astro";
import PnpmIcon from "../icons/PnpmIcon.astro";
import TypeScriptIcon from "../icons/TypeScriptIcon.astro";
import GitIcon from "../icons/GitIcon.astro";
import GitHubIcon from "../icons/GitHubIcon.astro";
import TerminalIcon from "../icons/TerminalIcon.astro";
import JavaScriptIcon from "../icons/JavaScriptIcon.astro";
import HtmlIcon from "../icons/HtmlIcon.astro";
import PythonIcon from "../icons/PythonIcon.astro";
import CssIcon from "../icons/CssIcon.astro";
import TailwindIcon from "../icons/TailwindIcon.astro";
import SwiftIcon from "../icons/SwiftIcon.astro";

interface Props {
  topics: string[];
  size?: "card" | "sidebar";
}

const { topics, size = "card" } = Astro.props;
const safeTopics = Array.isArray(topics) ? topics : [];
const visibleTopics = safeTopics.slice(0, 3);

// Max z-index for the first topic mark, decreasing by 1 for each subsequent mark.
// Keep in sync with visibleTopics.slice(0, 3) — if that changes, update 10 accordingly.
const STARTING_Z_INDEX = 10;

const iconMap = {
  git: GitIcon,
  github: GitHubIcon,
  npm: NpmIcon,
  pnpm: PnpmIcon,
  terminal: TerminalIcon,
  typescript: TypeScriptIcon,
  javascript: JavaScriptIcon,
  html: HtmlIcon,
  css: CssIcon,
  tailwind: TailwindIcon,
  python: PythonIcon,
  swift: SwiftIcon,
};

const renderedTopics = visibleTopics.map((topic, index) => ({
  topic,
  Icon: iconMap[topic.toLowerCase() as keyof typeof iconMap],
  zIndex: STARTING_Z_INDEX - index,
}));
---

{
  renderedTopics.length > 0 && (
    <div
      class={
        size === "card"
          ? "flex items-center -space-x-3"
          : "flex items-center gap-2"
      }
    >
      {renderedTopics.map(({ topic, Icon, zIndex }) => (
        <div
          class:list={[
            "relative inline-flex items-center justify-center rounded-2xl border font-semibold uppercase tracking-[0.08em]",
            "border-line bg-panel text-muted dark:text-ink",
            size === "card"
              ? "h-14 w-14 p-2 shadow-soft ring-1 ring-white/60 dark:ring-white/6"
              : "h-8 w-8 p-1.5",
          ]}
          style={size === "card" ? `z-index:${zIndex}` : undefined}
          aria-label={topic}
          title={topic}
        >
          {Icon ? (
            <Icon class="h-full w-full" />
          ) : (
            <span class={size === "card" ? "text-sm" : "text-[0.6rem]"}>
              {topic.slice(0, 3)}
            </span>
          )}
        </div>
      ))}
    </div>
  )
}
