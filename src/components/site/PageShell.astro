---
interface Props {
  size?: "wide" | "reading";
  class?: string;
}

const { size = "wide", class: className } = Astro.props;
---

<main id="main-content"
  class:list={[
    "mx-auto w-full px-4 sm:px-5",
    size === "wide" ? "max-w-[78rem]" : "max-w-3xl",
    className,
  ]}
>
  <slot />
</main>
