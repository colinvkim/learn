---
import {
  getLessonHref,
  getLessonSlug,
  getPublishedCourses,
  getPublishedLessonsForCourse,
  type CourseEntry,
} from "../../../lib/content/queries";

export async function getStaticPaths() {
  const courses = await getPublishedCourses();

  return courses.map((course) => ({
    params: { course: course.id },
    props: { course },
  }));
}

const { course } = Astro.props as { course: CourseEntry };
const lessons = await getPublishedLessonsForCourse(course.id);
const firstLesson = lessons[0];

if (!firstLesson) {
  throw new Error(`Published course "${course.id}" must include at least one published lesson.`);
}

const redirectHref = getLessonHref(course.id, getLessonSlug(firstLesson));
void redirectHref;

return Astro.redirect(redirectHref);
---
