---
import { render, type CollectionEntry } from "astro:content";
import ContentArticle from "../../../components/site/ContentArticle.astro";
import DocsLayout from "../../../components/site/DocsLayout.astro";
import LessonPager from "../../../components/site/LessonPager.astro";
import {
  getCourseHref,
  getLessonContext,
  getLessonSlug,
  getPublishedLessons,
} from "../../../lib/content/queries";

type LessonProps = {
  lesson: CollectionEntry<"lessons">;
};

export async function getStaticPaths() {
  const lessons = await getPublishedLessons();

  return lessons.map((lesson) => ({
    params: {
      course: lesson.data.course.id,
      lesson: getLessonSlug(lesson),
    },
    props: { lesson },
  }));
}

const { lesson } = Astro.props as LessonProps;
const context = await getLessonContext(lesson.data.course.id, getLessonSlug(lesson));

if (!context) {
  throw new Error(`Unable to resolve lesson context for "${lesson.id}".`);
}

const { course, previousLesson, nextLesson } = context;
const { Content } = await render(lesson);
const title = `${lesson.data.title} | ${course.data.title} | learn`;
const currentLessonSlug = getLessonSlug(lesson);
---

<DocsLayout
  title={title}
  description={lesson.data.description}
  course={course}
  lessons={context.lessons}
  currentLessonSlug={currentLessonSlug}
  breadcrumbs={[
    { label: "Home", href: "/" },
    { label: course.data.title, href: getCourseHref(course.id) },
    { label: lesson.data.title },
  ]}
>
  <header
    class="space-y-4 border-b border-line/80 pb-8"
    transition:name="lesson-header"
  >
    <div class="space-y-3">
      <h1 class="text-4xl font-semibold tracking-[-0.05em] text-ink sm:text-5xl">
        {lesson.data.title}
      </h1>
      <p class="max-w-3xl text-[1.02rem] leading-7 text-muted sm:text-lg sm:leading-8">
        {lesson.data.description}
      </p>
    </div>
  </header>

  <div class="space-y-7" transition:name="lesson-body">
    <ContentArticle class="pt-1">
      <Content />
    </ContentArticle>

    <LessonPager courseId={course.id} previousLesson={previousLesson} nextLesson={nextLesson} />
  </div>
</DocsLayout>
