---
import BaseLayout from "../components/site/BaseLayout.astro";
import CourseGrid from "../components/site/CourseGrid.astro";
import PageShell from "../components/site/PageShell.astro";
import { getPublishedCourseSummaries } from "../lib/content/queries";

const summaries = await getPublishedCourseSummaries();
---

<BaseLayout
  title="learn"
  description="A practical learning platform for modern tools, frameworks, and best practices."
  showHeader={false}
>
  <PageShell class="pb-20 pt-14 sm:pb-24 sm:pt-18">
    <section class="space-y-6">
      <div class="mx-auto max-w-5xl space-y-4">
        <h1
          class="text-3xl font-semibold text-ink sm:text-4xl lg:text-5xl min-h-[1.2em]"
        >
          <span id="rotating-text" class="text-primary inline-block"></span>
        </h1>

        <script is:inline>
          const topics = [
            "Explore authentication and security...",
            "Build skills in API design...",
            "Dive into database fundamentals...",
            "Learn about testing strategies...",
            "Explore deployment techniques...",
            "Master performance optimization...",
            "Discover state management patterns...",
            "Explore server-side rendering...",
            "Discover component-driven architecture...",
            "Learn version control workflows...",
          ];

          let intervalId = null;

          function pickRandom(exclude) {
            let topic;
            do {
              topic = topics[Math.floor(Math.random() * topics.length)];
            } while (topic === exclude && topics.length > 1);
            return topic;
          }

          function initTextAnimation() {
            const el = document.getElementById("rotating-text");
            if (!el) return;

            // Cancel any existing animations and clear interval
            el.getAnimations().forEach((a) => a.cancel());
            if (intervalId) {
              clearInterval(intervalId);
              intervalId = null;
            }

            // Reset state
            el.textContent = "";

            function animateIn(text) {
              el.textContent = text;
              el.animate(
                [
                  {
                    opacity: 0,
                    transform: "translateY(20px)",
                    filter: "blur(4px)",
                  },
                  { opacity: 1, transform: "translateY(0)", filter: "blur(0px)" },
                ],
                {
                  duration: 800,
                  easing: "cubic-bezier(0.16, 1, 0.3, 1)",
                  fill: "forwards",
                },
              );
            }

            function animateOut() {
              return el.animate(
                [
                  { opacity: 1, transform: "translateY(0)", filter: "blur(0px)" },
                  {
                    opacity: 0,
                    transform: "translateY(-16px)",
                    filter: "blur(4px)",
                  },
                ],
                {
                  duration: 300,
                  easing: "cubic-bezier(0.7, 0, 0.84, 0)",
                  fill: "forwards",
                },
              );
            }

            // Start with a random topic
            animateIn(pickRandom(null));

            // Set up rotation interval
            intervalId = setInterval(async () => {
              await animateOut().finished;
              animateIn(pickRandom(el.textContent));
            }, 3000);
          }

          // Run on initial page load
          initTextAnimation();

          // Re-run after view transitions
          document.addEventListener("astro:page-load", initTextAnimation);
        </script>

        <CourseGrid summaries={summaries} />
      </div>
    </section>
  </PageShell>
</BaseLayout>
