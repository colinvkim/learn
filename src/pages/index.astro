---
import BaseLayout from "../components/site/BaseLayout.astro";
import CourseGrid from "../components/site/CourseGrid.astro";
import PageShell from "../components/site/PageShell.astro";
import { getPublishedCourseSummaries } from "../lib/content/queries";

const summaries = await getPublishedCourseSummaries();
const hasCourses = summaries.length > 0;
---

<BaseLayout
  title="learn"
  description="A practical learning platform for modern tools, frameworks, and best practices."
  showHeader={false}
>
  <PageShell class="pb-20 pt-14 sm:pb-24 sm:pt-18">
    <section class="space-y-6">
      <div class="mx-auto max-w-5xl space-y-4">
        <h1
          class="text-3xl font-semibold tracking-[-0.055em] text-ink sm:text-4xl lg:text-5xl"
        >
          Start learning about...
        </h1>

        {
          hasCourses ? (
            <CourseGrid summaries={summaries} />
          ) : (
            <div class="rounded-xl border border-line/80 bg-panel/95 px-5 py-6 shadow-soft ring-1 ring-white/50 dark:ring-white/6">
              <p class="text-lg font-medium tracking-[-0.02em] text-ink">
                The first finished courses are still in progress.
              </p>
              <p class="mt-3 text-base leading-7 text-muted">
                The goal is a catalog that stays current, practical, and
                consistently useful.
              </p>
            </div>
          )
        }
      </div>
    </section>
  </PageShell>
</BaseLayout>
